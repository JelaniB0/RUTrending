generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Building {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  campus  Campus
  reports Report[]

  @@map("buildings")
}

model Staff {
  id                Int           @id @default(autoincrement())
  full_name         String
  username          String?       @unique
  role              StaffRole
  phone             String?
  email             String?       @unique
  report_staff      ReportStaff[]
  submitted_reports Report[]      @relation("SubmittedBy")

  @@map("staff")
}

model Report {
  id                  Int                    @id @default(autoincrement())
  report_id           String                 @unique
  building_id         Int
  specific_location   String
  nature              ReportNature
  policy_type         PolicyType?
  severity_level      MentalHealthSeverity?
  concern_type        String?
  issue_type          String?
  date                DateTime               @db.Date
  time                String
  narrative           String
  submitted_by_id     Int
  rupd_called         Boolean                @default(false)
  cad_number          String?
  ems_present         Boolean                @default(false)
  transported         Boolean                @default(false)
  emergency_single    String?
  created_at          DateTime               @default(now())
  updated_at          DateTime               @updatedAt
  narrative_embedding Unsupported("vector")?
  report_staff        ReportStaff[]
  involved_students   ReportStudent[]
  building            Building               @relation(fields: [building_id], references: [id])
  submitted_by        Staff                  @relation("SubmittedBy", fields: [submitted_by_id], references: [id])
  timeline_events     TimelineEvent[]

  @@index([building_id])
  @@index([nature])
  @@index([date])
  @@index([rupd_called])
  @@map("reports")
}

model ReportStaff {
  id             Int          @id @default(autoincrement())
  report_id      Int
  staff_id       Int
  role_in_report RoleInReport
  report         Report       @relation(fields: [report_id], references: [id])
  staff          Staff        @relation(fields: [staff_id], references: [id])

  @@unique([report_id, staff_id])
  @@map("report_staff")
}

model Student {
  id              Int             @id @default(autoincrement())
  first_name      String
  last_name       String
  ruid            String?         @unique
  dob             DateTime?       @db.Date
  phone           String?
  email           String?
  hall            String?
  report_students ReportStudent[]

  @@map("students")
}

model ReportStudent {
  id         Int         @id @default(autoincrement())
  report_id  Int
  student_id Int
  role       StudentRole
  notes      String?
  report     Report      @relation(fields: [report_id], references: [id])
  student    Student     @relation(fields: [student_id], references: [id])

  @@unique([report_id, student_id])
  @@map("report_students")
}

model TimelineEvent {
  id          Int      @id @default(autoincrement())
  report_id   Int
  event_time  String
  event_date  DateTime @db.Date
  actor       String
  description String
  sequence    Int
  report      Report   @relation(fields: [report_id], references: [id])

  @@index([report_id])
  @@map("timeline_events")
}

enum Campus {
  COLLEGE_AVE   @map("College Ave")
  BUSCH         @map("Busch")
  COOK_DOUGLASS @map("Cook/Douglass")
  LIVINGSTON    @map("Livingston")
}

enum StaffRole {
  RA
  ARLC
  RLC
}

enum ReportNature {
  TITLE_IX          @map("Title IX")
  MENTAL_HEALTH     @map("Mental Health Concern")
  POLICY_VIOLATION  @map("Policy Violation")
  ROOMMATE_CONFLICT @map("Roommate Conflict")
  GENERAL_CONCERN   @map("General Residence Life Concern")
  FACILITIES        @map("Facilities Issues")
}

enum PolicyType {
  DRUG_CANNABIS
  ALCOHOL_UNDERAGE
  FIRE_SAFETY_HOTPLATE
  FIRE_SAFETY_CANDLE
  FIRE_SAFETY_LITHIUM
  NOISE
  GUEST_OVERSTAY
  GUEST_PROPPED
  PROHIBITED_ITEM
  VANDALISM
  SMOKING
  DISRUPTION
  WEAPONS
}

enum MentalHealthSeverity {
  LOW
  MEDIUM
  HIGH
  CRISIS
}

enum StudentRole {
  ACCUSED
  VICTIM
  WITNESS
  STUDENT_OF_CONCERN
  INVOLVED_PARTY
  FACILITIES_CONCERN
  NO_STUDENT_INVOLVED
}

enum RoleInReport {
  RA
  ARLC
  RLC
}
